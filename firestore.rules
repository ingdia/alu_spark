rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //==========================================================================
    // HELPERS
    //==========================================================================

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() &&
             request.auth.uid == uid;
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function role() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == "ngabirediane02@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          role() == "admin"
        )
      );
    }

    function verified() {
      return signedIn() &&
        (
          request.auth.token.email_verified == true ||
          isAdmin()
        );
    }

    function isStudent() {
      return verified() &&
             role() == "student";
    }

    function isFounder() {
      return verified() &&
             role() == "founder";
    }

    //==========================================================================
    // USERS
    //==========================================================================

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read:   if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    //==========================================================================
    // STUDENTS
    //==========================================================================

    match /students/{uid} {
      allow read:   if verified();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();
    }

    //==========================================================================
    // STARTUPS
    //==========================================================================

    match /startups/{uid} {
      allow read:   if verified();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    //==========================================================================
    // OPPORTUNITIES
    //==========================================================================

    match /opportunities/{opportunityId} {
      allow read: if verified();

      allow create: if isFounder();

      // Startup owner or admin may update anything.
      // Any verified user may increment applicationsCount by exactly 1 only.
      allow update:
        if isAdmin()
        || (verified() && resource.data.startupId == request.auth.uid)
        || (verified()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['applicationsCount'])
            && request.resource.data.applicationsCount
                == resource.data.applicationsCount + 1);

      allow delete:
        if isAdmin()
        || (verified() && resource.data.startupId == request.auth.uid);
    }

    //==========================================================================
    // APPLICATIONS
    //==========================================================================

    match /applications/{applicationId} {

      function opp() {
        return get(
          /databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId)
        );
      }

      function validOpportunity() {
        return exists(
            /databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId)
          ) &&
          opp().data.status == "active" &&
          opp().data.startupId == request.resource.data.startupId;
      }

      function noDuplicate() {
        return !exists(
          /databases/$(database)/documents/applications/$(request.auth.uid + "_" + request.resource.data.opportunityId)
        );
      }

      function immutableFieldsUnchanged() {
        return request.resource.data.studentId     == resource.data.studentId     &&
               request.resource.data.startupId     == resource.data.startupId     &&
               request.resource.data.opportunityId == resource.data.opportunityId;
      }

      allow read:
        if verified() &&
        (
          resource.data.studentId == request.auth.uid ||
          resource.data.startupId == request.auth.uid ||
          isAdmin()
        );

      allow create:
        if isStudent() &&
           request.resource.data.studentId == request.auth.uid &&
           validOpportunity() &&
           noDuplicate();

      allow update:
        if verified() &&
        immutableFieldsUnchanged() &&
        (
          isAdmin()
          ||
          resource.data.startupId == request.auth.uid
          ||
          (
            resource.data.studentId == request.auth.uid &&
            request.resource.data.status == "withdrawn"
          )
        );

      allow delete: if isAdmin();
    }

    //==========================================================================
    // BOOKMARKS
    //==========================================================================

    match /bookmarks/{uid}/opportunities/{opportunityId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    //==========================================================================
    // CONVERSATIONS
    //==========================================================================

    match /conversations/{conversationId} {

      function validParticipants() {
        return request.resource.data.participantIds.size() == 2 &&
               request.auth.uid in request.resource.data.participantIds;
      }

      function participantsUnchanged() {
        return request.resource.data.participantIds == resource.data.participantIds;
      }

      allow read:
        if signedIn() &&
        request.auth.uid in resource.data.participantIds;

      allow create:
        if signedIn() &&
        validParticipants();

      allow update:
        if signedIn() &&
        request.auth.uid in resource.data.participantIds &&
        participantsUnchanged();

      allow delete: if isAdmin();

      match /messages/{messageId} {

        function isParticipant() {
          return request.auth.uid in
            get(
              /databases/$(database)/documents/conversations/$(conversationId)
            ).data.participantIds;
        }

        allow read:   if signedIn() && isParticipant();
        allow create: if signedIn() && isParticipant() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if signedIn() && isParticipant();
        allow delete: if isAdmin();
      }
    }

    //==========================================================================
    // NOTIFICATIONS
    //==========================================================================

    match /notifications/{uid}/items/{notificationId} {
      allow read:   if isOwner(uid) || isAdmin();
      // verified() allows cross-user fan-out (student → founder, founder → student).
      allow create: if verified() || isAdmin();
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid) || isAdmin();
    }

    //==========================================================================
    // ROOMS
    //==========================================================================

    match /rooms/{roomId} {
      allow read:   if verified();
      allow create: if verified();
      allow update: if verified();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read:   if verified();
        allow create: if verified() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    //==========================================================================
    // ADMIN NOTIFICATIONS
    //==========================================================================

    match /admin_notifications/{notificationId} {
      allow read:   if isAdmin();
      allow create: if isAdmin() || verified();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

  }
}
